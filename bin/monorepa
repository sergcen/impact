#!/bin/sh
set -eu

repository_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
binary="$repository_root/target/release/monorepa"

if [ ! -x "$binary" ] || find "$repository_root/rust" "$repository_root/Cargo.toml" "$repository_root/Cargo.lock" -type f -newer "$binary" -print -quit | grep -q .; then
  cargo build --release --manifest-path "$repository_root/Cargo.toml" >&2
fi

exec "$binary" "$@"
